# Скопируйте в `.env` в корне репозитория (`live-chat-blog/.env`).
# Не коммитьте `.env` с секретами.

# =============================================================================
# РЕЖИМ РАЗРАБОТКИ (активируйте этот блок локально перед рефакторингом)
# =============================================================================
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Явный ключ не обязателен при DEBUG — подставится dev-default из settings.py
# DJANGO_SECRET_KEY=local-dev-only

# Без локального PostgreSQL — раскомментируйте (на проде никогда не включать):
# DJANGO_USE_SQLITE=true

# Формы / логин в браузере на runserver (стандартный порт 8000):
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Если collectstatic ругается на отсутствующие .map:
# DJANGO_MANIFEST_STATICFILES=false

# --- PostgreSQL (локировка когда DJANGO_USE_SQLITE не задан) ---
DJANGO_DB_NAME=liveblog
DJANGO_DB_USER=your_db_user
DJANGO_DB_PASSWORD=your_db_password
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432
# DJANGO_DB_CONN_MAX_AGE=60

# =============================================================================
# ПРОДАКШЕН (раскомментируйте и заполните перед финальным деплоем; DEBUG должен быть false)
# =============================================================================
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=сгенерировать-длинный-случайный-ключ
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_DB_NAME=...
# DJANGO_DB_USER=...
# DJANGO_DB_PASSWORD=...
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=5432

# Optional: Redis cache (если не задан — LocMem)
# REDIS_URL=redis://127.0.0.1:6379/1

# Celery
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0

# SPELLCHECK_LANG=en

# =============================================================================
# БЕЗОПАСНОСТЬ (см. docs/SECURITY.md, docs/API_SECURITY.md)
# =============================================================================
# CSP: полная строка политики или пусто = встроенный default в middleware
# DJANGO_SECURITY_CSP=
# DJANGO_SECURITY_CSP_REPORT_ONLY=false
# DJANGO_SECURITY_HEADERS=true
#
# Сессия
# SESSION_COOKIE_SAMESITE=Lax
# SESSION_COOKIE_AGE=1209600
#
# Лимиты (django-ratelimit; для прода лучше Redis как CACHE)
# RATELIMIT_LOGIN_RATE=5/15m
# RATELIMIT_REGISTER_RATE=5/h
# RATELIMIT_SEARCH_RATE=60/m
# RATELIMIT_TRENDING_RATE=120/m
# RATELIMIT_ITEM_COUNTERS_RATE=90/m
# RATELIMIT_SEARCH_HISTORY_RATE=120/m
# RATELIMIT_REPORT_POST_RATE=40/m
